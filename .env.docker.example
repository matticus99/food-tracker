# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=food_tracker

# Server
# NOTE: If your password contains special characters (#, ^, @, etc.),
# they must be percent-encoded in the URL (e.g. # → %23, ^ → %5E).
DATABASE_URL=postgresql://postgres:changeme@db:5432/food_tracker
PORT=3001
CORS_ORIGIN=http://localhost

